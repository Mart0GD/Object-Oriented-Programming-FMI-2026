{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-solutions",
      "type": "shell",
      "command": "g++",
      "args": [
        "*.cpp",
        "-std=c++17",
        "-g",
        "-O0",
        "-o",
        "program"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run-solutions",
      "type": "shell",
      "dependsOn": "build-solutions",
      "command": "./program"
    }
  ]
}